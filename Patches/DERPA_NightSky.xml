<?xml version="1.0" encoding="utf-8" ?>
<Patch>

    <!--
      Darken outdoor nights. Night glow is already ~0 (measured), so what you SEE
      at night is the night sky COLOUR painting the lighting overlay
      (SkyManagerUpdate: MatBases.LightOverlay.color = curSky.colors.sky), not a
      light level. So the lever is the sky node in the night blocks:
        skyColorsNightMid  = deep night
        skyColorsNightEdge = the edges of night (toward dusk/dawn)

      The xpath has no [defName] predicate, so it matches EVERY WeatherDef that
      declares these blocks, and the replace applies to every match. We replace only
      the sky node (the brightness/tint), leaving each weather's own shadow / overlay
      / saturation intact.

      The whole sequence is wrapped in DERPA's PatchOperationDarknessGate, so it only
      applies when the "Darken unlit areas" mod setting is on. (Load-time patch, so
      toggling it takes effect on the next game restart.)

      Values are (R,G,B) 0..1. Lower = darker. Slight blue bias for a night feel.
    -->

    <Operation Class="DERPA.PatchOperationDarknessGate">
        <operations>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/WeatherDef/skyColorsNightMid/sky</xpath>
                <value>
                    <sky>(0.05,0.05,0.09)</sky>
                </value>
            </li>
            <li Class="PatchOperationReplace">
                <xpath>/Defs/WeatherDef/skyColorsNightEdge/sky</xpath>
                <value>
                    <sky>(0.05,0.05,0.09)</sky>
                </value>
            </li>
        </operations>
    </Operation>

</Patch>
